        <h2>{{this.stage}}</h2>
        <ul>
            {{#each this.bussiness}}
            <li>{{this.nombre}} - {{this.value}} - {{this.deadline}}</li>
            {{/each}}
        </ul>
    </div>
    {{/each}}
