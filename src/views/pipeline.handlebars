<div class="admin-element" title="Añade una etapa" id="adminElement">
   <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" fill="currentColor" class="bi bi-node-plus-fill" viewBox="0 0 16 16">
  <path d="M11 13a5 5 0 1 0-4.975-5.5H4A1.5 1.5 0 0 0 2.5 6h-1A1.5 1.5 0 0 0 0 7.5v1A1.5 1.5 0 0 0 1.5 10h1A1.5 1.5 0 0 0 4 8.5h2.025A5 5 0 0 0 11 13m.5-7.5v2h2a.5.5 0 0 1 0 1h-2v2a.5.5 0 0 1-1 0v-2h-2a.5.5 0 0 1 0-1h2v-2a.5.5 0 0 1 1 0"/>
</svg>
</div>
  <div class="modal" id="adminModal">
    <div class="modal-content">
      <span class="close" id="closeModal">&times;</span>
      <h2>Añadir etapa</h2>
        <form id="contactForm">
            <label for="name">Nombre</label>
            <input type="text" id="name" name="name" required>

            <label for="value">Valor</label>
            <input type="text" id="value" name="value" required>

            <label for="deadline">Fecha de cierre</label>
            <input type="date" id="deadline" name="deadline">
            <button type="submit" class="addStageButton">Crear etapa</button>
        </form>
    </div>
  </div>


