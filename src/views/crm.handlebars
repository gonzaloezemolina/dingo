<div class="tools">




    


    <div class="contact_list">
        {{#if contacts.length}}
            <div class="table-container">
                <table id="contactTable">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Teléfono</th>
                            <th>Estado de Lead</th>
                            <th>Fuente de Lead</th>
                            <th>Canal preferido</th>
                            <th>Mapa de empatía</th>
                            <th>Último contacto</th>
                            <th>Creación</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each contacts}}
                            <tr>
                                <td>{{this.name}}</td>
                                <td>{{this.email}}</td>
                                <td>{{this.phone}}</td>
                                <td>{{this.status}}</td>
                                <td>{{this.source}}</td>
                                <td>{{this.channel}}</td>
                                <td>-</td>
                                <td>{{#if this.lastTouch}}{{this.lastTouch}}{{/if}}</td>
                                <td>{{this.creation}}</td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        {{else}}
            <p>No hay contactos disponibles.</p>
        {{/if}}
    </div>

    
</div>




















