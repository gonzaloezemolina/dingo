</svg>
</div>
  <div class="modal" id="adminModal">
    <div class="modal-content">
      <span class="close" id="closeModal">&times;</span>
      <h2>Añadir contacto</h2>
        <form id="contactForm">
            <label for="name">Nombre</label>
            <input type="text" id="name" name="name" required>
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
            <label for="phone">Teléfono</label>
            <input type="text" id="phone" name="phone" required>
            <label for="status">Estado del lead</label>
<select id="status" name="status" required>
    <option value="activo">Nuevo</option>
    <option value="en negociacion">En negociacion</option>
    <option value="calificado">Calificado</option>
    <option value="intento de contacto">Intento de contacto</option>
    <option value="ganado">Ganado</option>
    <option value="mal momento">Mal momento</option>
    <option value="perdido">Perdido</option>
</select>

<label for="source">Fuente del lead</label>
<select id="source" name="source" required>
    <option value="referido">Referido</option>
    <option value="sitio web">Sitio web</option>
    <option value="evento">Evento</option>
    <option value="campaña de email marketing">Campaña email marketing</option>
    <option value="redes sociales">Redes sociales</option>
    <option value="SEO">SEO</option>
    <option value="telemarketing">Telemarketing</option>
    <option value="Inbound marketing">Inbound marketing</option>
    <option value="base de datos/compra de listas">Bases de Datos/Compra de Listas</option>
    <option value="publicidad en medios tradicionales">Publicidad en Medios Tradicionales</option>
    <option value="otro">Otro</option>
</select>

<label for="channel">Canal</label>
<select id="channel" name="channel" required>
    <option value="telefono">Teléfono</option>
    <option value="correo">Correo electrónico</option>
    <option value="presencial">Presencial</option>
    <option value="Linkedin">Linkedin</option>
    <option value="whatsapp">Whatsapp</option>
    <option value="instagram">Instagram</option>
</select>

            <label for="lastTouch">Último contacto</label>
            <input type="date" id="lastTouch" name="lastTouch">
            <button type="submit" class="addContactButton">Crear contacto</button>
        </form>
    </div>
  </div>


</div>



